# Database — Using SQLite for easy local development (no install needed!)
# For PostgreSQL, change to: postgresql://username:password@localhost:5432/grocerylens
DATABASE_URL="file:./dev.db"

# JWT Secret — Used to sign login tokens. Change this to any random string.
JWT_SECRET="change-me-to-a-random-secret-string-abc123"

# Server port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL="https://grocery-lens-web.vercel.app/"
